<?xml version="1.0" encoding="windows-1252"?>
<!--
  Programmer-Wander WiX installer template.
  Built by cargo-wix on tag-push via .github/workflows/build.yml.
  UpgradeCode + Component GUIDs are stable across versions for proper upgrade tracking.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*"
             Name="Programmer-Wander"
             UpgradeCode="83A6A989-E6FC-4C7F-9BDC-5FBF15B22730"
             Manufacturer="AIWander"
             Language="1033"
             Codepage="1252"
             Version="$(var.Version)">

        <Package Id="*"
                 Keywords="Installer"
                 Description="Programmer-Wander â€” MCP server giving any AI a complete Rust + Windows dev shell"
                 Manufacturer="AIWander"
                 InstallerVersion="450"
                 Languages="1033"
                 Compressed="yes"
                 InstallScope="perMachine"
                 SummaryCodepage="1252"
                 Platform="$(var.Platform)"/>

        <MajorUpgrade
            Schedule="afterInstallInitialize"
            DowngradeErrorMessage="A newer version of Programmer-Wander is already installed. Setup will now exit."/>

        <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" DiskPrompt="CD-ROM #1"/>
        <Property Id="DiskPrompt" Value="Programmer-Wander Installation"/>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="$(var.PlatformProgramFilesFolder)" Name="PFiles">
                <Directory Id="APPLICATIONFOLDER" Name="Programmer-Wander">
                    <Component Id="License" Guid="*" Win64="$(var.Win64)">
                        <File Id="LicenseFile" Name="LICENSE" DiskId="1" Source="LICENSE" KeyPath="yes"/>
                    </Component>
                    <Component Id="Programmer" Guid="2F73BE95-7204-4362-B764-B003AE2101FD" Win64="$(var.Win64)">
                        <File Id="ProgrammerExe"
                              Name="programmer.exe"
                              DiskId="1"
                              Source="$(var.CargoTargetBinDir)\programmer.exe"
                              KeyPath="yes"/>
                    </Component>
                    <Component Id="ProgrammerPath" Guid="E450F36E-D871-4D5F-A78B-90415E1E4132" Win64="$(var.Win64)" KeyPath="yes">
                        <Environment Id="ProgrammerPathEnv"
                                     Name="PATH"
                                     Value="[APPLICATIONFOLDER]"
                                     Permanent="no"
                                     Part="last"
                                     Action="set"
                                     System="yes"/>
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <Feature Id="MainProgram"
                 Title="Programmer-Wander"
                 Description="The programmer.exe binary"
                 Level="1"
                 ConfigurableDirectory="APPLICATIONFOLDER"
                 AllowAdvertise="no"
                 Display="expand"
                 Absent="disallow">
            <ComponentRef Id="License"/>
            <ComponentRef Id="Programmer"/>
            <Feature Id="Path"
                     Title="Add to PATH"
                     Description="Add programmer.exe to system PATH"
                     Level="1">
                <ComponentRef Id="ProgrammerPath"/>
            </Feature>
        </Feature>

        <Property Id="ARPHELPLINK" Value="https://github.com/AIWander/Programmer-Wander/issues"/>
        <Property Id="ARPURLINFOABOUT" Value="https://github.com/AIWander/Programmer-Wander"/>
        <Property Id="ARPURLUPDATEINFO" Value="https://github.com/AIWander/Programmer-Wander/releases"/>

        <SetProperty Id="ARPINSTALLLOCATION" Value="[APPLICATIONFOLDER]" After="CostFinalize"/>
    </Product>
</Wix>
